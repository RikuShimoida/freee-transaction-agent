# freee API クレデンシャル（このファイルをコピーして .env.local を作り、値を埋めてください）
# .env.local は .gitignore 済みなので Git にはコミットされません。

# freee 開発者アプリの「アクセストークンの確認・取得」で発行したトークン
FREEE_ACCESS_TOKEN=
FREEE_REFRESH_TOKEN=

# freee アプリの Client ID / Secret（トークン自動リフレッシュに使用。検証だけなら未設定でも可）
FREEE_CLIENT_ID=
FREEE_CLIENT_SECRET=

# 事業所ID（検証スクリプトが自動取得するので、最初は空でOK）
FREEE_COMPANY_ID=

# Claude API キー（未マッチ明細の費目推定に使用）
ANTHROPIC_API_KEY=

# LINE Messaging API（グレー案件の通知先）
LINE_CHANNEL_ACCESS_TOKEN=
LINE_TO_USER_ID=

# Cron/手動トリガーの認証シークレット（任意の長い文字列）
CRON_SECRET=

# Upstash Redis（本番のトークン永続化用。ローカルは未設定で.env.localを使う）
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
